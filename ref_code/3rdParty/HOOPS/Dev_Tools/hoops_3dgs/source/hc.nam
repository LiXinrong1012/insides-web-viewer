/*
 * HOOPS export naming file
 *
 * Routines with HC_ prefixes will have prototypes and
 * language glue generated.
 * 
 * We not longer generate export files, so the order of functions
 * is not guaranteed in dynamic libraries, so users generally need to
 * relink against new versions.  The order is currently just historical
 * (new ones added at the end with version comments)
 *
 * This file #define's shortened forms of the Hoops routine name for
 * those routines that can be called by the user.  Hoops subroutine 
 * specifications...
 *
 *  Comment fields are argument-types plus return-type
 *  Second comment may be specified for alternate function namings
 *	(a comma separated list of one or more names)
 *
 *  Possible data types are:
 *
 *    a - 4x4 array
 *    b - boolean				<- return value only ->
 *    c - character (byte) array (NOT strings)
 *    f - float					<- may be returned ->
 *    i - integer				<- may be returned ->
 *    j - array of keys
 *    k - key					<- may be returned ->
 *    l - long integer
 *    m - pointer sized integer			    [user value]
 *    p - point (one or more)
 *    q - plane (one or more)
 *    r - subroutine address (== int (*)() )
 *    s - string
 *    t - subroutine address (== void (*)() )
 *    u - void * (unknown)			    [user index, image data, special]
 *    v - void					<- may be returned ->
 *    x - array of unsigned short integers	    [pixel array, unicode text]
 *    y	- array of regular integers		    [shell face list]
 *    z - array of floats			    [FIndex list]
 *
 *  Capital letters are for modified/written arguments,
 *  return type always lowercase.
 *
 *  Here are the actual C type maps. See hc.h for HC_ defines:
 *
 *    A : float *
 *    a : const float *
 *    b : HC_BOOLEAN
 *    C : char *
 *    c : const char *
 *    F : float *
 *    f : double
 *    I : int *
 *    i : int
 *    J : HC_KEY *
 *    j : const HC_KEY *
 *    K : HC_KEY *
 *    k : HC_KEY
 *    L : long *
 *    l : long
 *    M : HC_POINTER_SIZED_INT *
 *    m : HC_POINTER_SIZED_INT
 *    P : HC_POINT *
 *    p : const HC_POINT *
 *    Q : HC_PLANE *
 *    q : const HC_PLANE *
 *    R : int(HC_CDECL **)(HC_ANY_ARGS)
 *    r : int(HC_CDECL *)(HC_ANY_ARGS)
 *    S : char *
 *    s : const char *
 *    T : void(HC_CDECL **)(HC_ANY_ARGS)
 *    t : void(HC_CDECL *)(HC_ANY_ARGS)
 *    U : void *
 *    u : const void *
 *    v : void
 *    X : unsigned short *
 *    x : const unsigned short *
 *    Y	: int *
 *    y	: const int *
 *    Z : float *
 *    z : const float *
 */

