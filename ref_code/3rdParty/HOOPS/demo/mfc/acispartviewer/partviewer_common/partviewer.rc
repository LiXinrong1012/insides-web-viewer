/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDR_MAINFRAME           ICON                    "hoops.ico"
IDR_HOOPSTYPE           ICON                    "parasolid.ico"
IDR_MAINFRAME1          ICON                    "hoops.ico"
IDR_HOOPSTYPE1          ICON                    "spatial.ico"
IDR_MAINFRAME2          ICON                    "hoops.ico"
IDR_HOOPSTYPE2          ICON                    "ptc.ico"
IDR_MAINFRAME3          ICON                    "hoops.ico"
IDR_HOOPSTYPE3          ICON                    "hoops.ico"
IDI_ITEM_CHECKED        ICON                    "item_checked.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New...\tCtrl+N",             ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "P&rint Setup...",             ID_FILE_PRINT_SETUP
        MENUITEM SEPARATOR
        MENUITEM "Recent Files",                ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&View"
    BEGIN
        POPUP "&Toolbar"
        BEGIN
            MENUITEM "&Standard",                   ID_VIEW_TOOLBAR
            MENUITEM "&Tools",                      ID_VIEW_TOOLBAR_TOOLS
            MENUITEM "&Markup-Text",                ID_VIEW_TOOLBAR_MARKUP_TEXT
            MENUITEM "Standard &Views",             ID_WINDOW_SPLIT
            MENUITEM "CAE",                         ID_TOOLBAR_CAE
            MENUITEM "CMM",                         ID_TOOLBAR_CMM
            MENUITEM "Point Cloud",                 ID_TOOLBAR_POINT_CLOUD
        END
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&Options...",                 ID_TOOLS_OPTIONS
    END
    POPUP "&Performance"
    BEGIN
        MENUITEM "Default",                     ID_PERFORMANCE_DEFAULT
        MENUITEM "High Performance",            ID_PERFORMANCE_HIGH
        MENUITEM SEPARATOR
        MENUITEM "Static Model",                ID_PERFORMANCE_STATIC_MODEL
        MENUITEM SEPARATOR
        MENUITEM "Segment-Level Display Lists", ID_PERFORMANCE_SEGMENT_LEVEL_DL
        MENUITEM "Geometry-Level Display Lists", ID_PERFORMANCE_GEOMETRY_LEVEL_DL
        MENUITEM SEPARATOR
        MENUITEM "Fixed Framerate",             ID_PERFORMANCE_FIXED_FRAMERATE
        MENUITEM "Target Framerate",            ID_PERFORMANCE_TARGET_FRAMERATE
    END
    POPUP "&Effects"
    BEGIN
        MENUITEM "None",                        ID_EFFECTS_NONE
        MENUITEM "Fancy",                       ID_EFFECTS_FANCY
        MENUITEM SEPARATOR
        MENUITEM "&Focus On Selection",         ID_SELECTION_FOCUS
        MENUITEM "Ambient Occlusion",           ID_EFFECTS_AMBIENT_OCCLUSION
        MENUITEM "Bloom",                       ID_EFFECTS_BLOOM
        MENUITEM "Fast Silhouette Edges",       ID_EFFECTS_FAST_SILHOUETTE_EDGES
        MENUITEM "Reflection Plane",            ID_EFFECTS_REFLECTION_PLANE
        MENUITEM "Shadow Maps",                 ID_EFFECTS_SHADOW_MAPS
        MENUITEM "Simple Shadows",              ID_EFFECTS_SIMPLE_SHADOWS
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About ...",                  ID_APP_ABOUT
    END
END

IDR_HOOPSTYPE MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New...\tCtrl+N",             ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM "&Load...\tCtrl+L",            ID_FILE_LOAD
        MENUITEM "&Close",                      ID_FILE_CLOSE
        MENUITEM SEPARATOR
        MENUITEM "Save &As...",                 ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "&Print...\tCtrl+P",           ID_FILE_PRINT
        MENUITEM "Print Pre&view",              ID_FILE_PRINT_PREVIEW
        MENUITEM "P&rint Setup...",             ID_FILE_PRINT_SETUP
        MENUITEM SEPARATOR
        MENUITEM "Recent Files",                ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Tile",                       ID_WINDOW_TILE_HORZ
        POPUP "Tool&bar"
        BEGIN
            MENUITEM "&Standard",                   ID_VIEW_TOOLBAR
            MENUITEM "&Tools",                      ID_VIEW_TOOLBAR_TOOLS
            MENUITEM "&Markup-Text",                ID_VIEW_TOOLBAR_MARKUP_TEXT
            MENUITEM "Standard &Views",             ID_VIEW_TOOLBAR_STANDARD_VIEWS
            MENUITEM "Animation",                   ID_VIEW_TOOLBAR_ANIMATION
            MENUITEM "CAE",                         ID_TOOLBAR_CAE
