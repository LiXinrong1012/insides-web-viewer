IDR_VIEW_POPUP MENU 
BEGIN
    POPUP "TOOLS"
    BEGIN
        MENUITEM "Orbit",                       ID_ORBIT
        MENUITEM "Pan",                         ID_PAN
        MENUITEM "Zoom",                        ID_ZOOM_DIRECT
        MENUITEM "Zoom to Window",              ID_ZOOM_WINDOW
        MENUITEM SEPARATOR
        MENUITEM "Save As ...",                 ID_TOOLS_SAVEAS
        MENUITEM "Open ...",                    ID_FILEOPEN
        MENUITEM SEPARATOR
        MENUITEM "Optimize Model",              ID_TOOLS_OPTIMIZEMODEL
        MENUITEM "Reset Camera",                ID_RESET
        MENUITEM "Smooth Transition",           ID_TOOLS_SMOOTHTRANSITION
        MENUITEM SEPARATOR
        POPUP "Render Modes"
        BEGIN
            MENUITEM "Smooth Shaded",               ID_SMOOTH_SHADED
            MENUITEM "Flat Shaded",                 ID_FLAT_SHADED
            MENUITEM "Wireframe",                   ID_WIREFRAME
            MENUITEM "Hidden Line",                 ID_HIDDEN_LINE
        END
        POPUP "&Visibility"
        BEGIN
            MENUITEM "Lines",                       ID_TOOLS_VISIBILITY_LINES
            MENUITEM "Faces",                       ID_TOOLS_VISIBILITY_FACES
            MENUITEM "Text",                        ID_TOOLS_VISIBILITY_TEXT
        END
        MENUITEM SEPARATOR
        POPUP "Animation"
        BEGIN
            MENUITEM "Play",                        ID_BHV_PLAY
            MENUITEM "Pause",                       ID_BHV_PAUSE
            MENUITEM "Rewind",                      ID_BHV_REWIND
        END
        MENUITEM SEPARATOR
        MENUITEM "Shadow",                      ID_SHADOW_SMOOTH
        MENUITEM SEPARATOR
        MENUITEM "Print ...",                   ID_PRINT
        MENUITEM "Copy to Clipboard",           ID_COPY
        MENUITEM SEPARATOR
        MENUITEM "Window Color ...",            ID_WINDOW_COLOR
        MENUITEM "About ...",                   ID_ABOUT_BOX
    END
END


