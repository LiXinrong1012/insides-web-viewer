<!-- ①  整篇文档有且只有一个TYPE_INFO，为根节点，根节点下有多个TYPE，每个TYPE为一个关键字的介绍，包括属性，键值对等 -->
	<!-- 每个TYPE中 只有一个PROPERTY_GROUPS 节点， PROPERTY_GROUPS 中可以有多个 PROPERTY_GROUP , 每个 PROPERTY_GROUP 中也可以有多个 PROPERTY -->
	<!-- 每个TYPE中 KEY_VALUE的结构为一个KEY_VALUE下有多个二级KEY_VALUE,每个二级KEY_VALUE同样可以有下级的KEY_VALUE  -->
		<!-- VAILD_REFERENCE_TYPES="FEMPART,RIGIDPART"  当KEYNAME为PART或ASSEMBLY时 起作用，表明只有当引用的类型为FEMPART或RIGIDPART时才为合法引用 -->
		<!-- IS_MULTIPLE_KEYVALUE="1" 是否支持多选 只有在其有子节点时有效，1为可多选，0为不可多选 -->
		<!-- KEYNAME="RHO" 条目名称为RHO -->
		<!-- VAILD_UNDER_PROPERTIES="BOX" KEYNAME="LENGTH"  表名LENGTH只有在当前TYPE设置属性为BOX时才可以定义 -->
		<!-- COMPONENT_TYPE="" 表示单个分量的类型 -->
		<!-- CONPONENT_COUNT="0" 分量数目，当分量小于等于0时表示长度不固定 -->
		<!-- IS_REFERENCE="0" 是否为引用，目前只有PART，ASSEMBLY为引用,0为引用，1为非引用 -->
		<!-- IS_OPTIMAL="1" 该关键字是否可以不进行定义，为0时表示必须定义，为1时表示可以不定义 -->
		
<!-- ②  HELP="" 为该条目的相关帮助，可支持中文，关键字，属性，键值对均可有帮助，亦可留空 -->
<!-- ③  VALUE_COUNT="3" 表示 当前KEYNAME "ALPHA" 如果定义，则必须有3个值 -->
<!-- ④  GROUPE 为可以省略，可以多选，SELECT_COUNT="2" 表示如果多选则必须选择 E1,E2,E3中的两个 -->